{
  "name": "ris-cm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck &&  vite build",
    "preserve": "vite build",
    "serve": "vite preview",
    "clean": "rm -rf dist/",
    "typecheck": "vue-tsc --noEmit",
    "test": "TZ=UTC vitest run",
    "test:watch": "TZ=UTC vitest",
    "test:report": "TZ=UTC vitest run --reporter=html --outputFile=./test-results/unit-tests/report.html",
    "test:e2e": "playwright test --config=test/e2e/playwright.config.ts",
    "test:a11y": "playwright test --config=test/a11y/playwright.config.ts",
    "coverage": "jest test --coverage",
    "lint:check": "oxlint --max-warnings=0",
    "lint:fix": "npm run lint:check -- --fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write --ignore-unknown .",
    "style:check": "npm run format:check && npm run lint:check",
    "style:fix": "npm run format:fix && npm run lint:fix",
    "audit:licences": "license-checker-rseidelsohn --production --excludePrivatePackages --onlyAllow ''",
    "check": "npm run typecheck && npm run style:check && npm test && npm run test:e2e && npm run test:a11y"
  },
  "dependencies": {
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@playwright-testing-library/test": "^4.5.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-istanbul": "^4.1.0",
    "axe-playwright": "^2.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-playwright": "^2.10.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-testing-library": "^7.16.0",
    "jsdom": "^29.0.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "oxlint": "^1.56.0",
    "playwright": "^1.58.0",
    "prettier": "3.8.1",
    "prettier-plugin-sh": "^0.18.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=22"
  }
}
