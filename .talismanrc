fileignoreconfig:
  - filename: .github/workflows/pipeline.yml
    allowed_patterns:
      - "key: "
      - "password: "
      - TRIVY_PASSWORD
      - restore-keys
  - filename: .github/workflows/deploy-staging-job.yml
    allowed_patterns:
      - github_app_private_key
      - GITOPS_NEURIS_APP_PRIVATE_KEY
  - filename: .github/workflows/scan.yml
    allowed_patterns:
      - TRIVY_PASSWORD
  - filename: .github/workflows/tests-and-code-quality.yml
    allowed_patterns:
      - "key: "
  - filename: README.md
    allowed_patterns:
      - secrets
      - Secrets
  - filename: LICENSE
    allowed_patterns:
      - "keys"
  - filename: Dockerfile
    allowed_patterns:
      - "@sha256:[a-fA-F0-9]{64}"
  - filename: sonar-project.properties
    allowed_patterns:
      - projectKey
  - filename: nginx/default.conf
    checksum: 4ba1e5322d947b5a852625c4e815b4091792ed0d902b1dde93a1f13673b34ce9
  - filename: public/env.json
    ignore_detectors: [filename]
  - filename: src/lib/env.ts
    ignore_detectors: [filename]
scopeconfig:
  - scope: node
allowed_patterns:
  - uses:\ ([A-z0-9\-]+\/)*[A-z0-9\-]+@[a-fA-F0-9]{40}
  - "secrets: inherit"
