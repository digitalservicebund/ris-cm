fileignoreconfig:
  - filename: .github/workflows/pipeline.yml
    allowed_patterns:
      - "key: "
      - "password: "
      - TRIVY_PASSWORD
      - restore-keys
  - filename: .github/workflows/deploy-staging-job.yml
    allowed_patterns:
      - github_app_private_key
      - GITOPS_NEURIS_APP_PRIVATE_KEY
  - filename: .github/workflows/scan.yml
    allowed_patterns:
      - TRIVY_PASSWORD
  - filename: .github/workflows/tests-and-code-quality.yml
    allowed_patterns:
      - "key: "
  - filename: README.md
    allowed_patterns:
      - secrets
      - Secrets
  - filename: LICENSE
    allowed_patterns:
      - "keys"
  - filename: Dockerfile
    allowed_patterns:
      - "@sha256:[a-fA-F0-9]{64}"
      - "--mount=type=secret,id=SENTRY_AUTH_TOKEN"
  - filename: sonar-project.properties
    allowed_patterns:
      - projectKey
  - filename: nginx/default.conf
    checksum: 734a6a75350c4804a69ffddffd91507f790a3011a6f7ef488ddd958932ee21bc
  - filename: public/config/env.json
    ignore_detectors: [filename]
  - filename: src/lib/env.ts
    ignore_detectors: [filename]
  - filename: doc/adr/0004-environment-specific-configuration.md
    ignore_detectors: [filename]
scopeconfig:
  - scope: node
allowed_patterns:
  - uses:\ ([A-z0-9\-]+\/)*[A-z0-9\-]+@[a-fA-F0-9]{40}
  - "secrets: inherit"
  - Keycloak
  - keycloak
