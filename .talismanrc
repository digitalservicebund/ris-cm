fileignoreconfig:
  - filename: .github/workflows/pipeline.yml
    allowed_patterns:
      - "key: "
      - "password: "
      - TRIVY_PASSWORD
      - restore-keys
  - filename: .github/workflows/deploy-staging-job.yml
    allowed_patterns:
      - github_app_private_key
      - GITOPS_NEURIS_APP_PRIVATE_KEY
  - filename: .github/workflows/scan.yml
    allowed_patterns:
      - TRIVY_PASSWORD
  - filename: .github/workflows/tests-and-code-quality.yml
    allowed_patterns:
      - "key: "
  - filename: README.md
    allowed_patterns:
      - secrets
      - Secrets
  - filename: LICENSE
    allowed_patterns:
      - "keys"
  - filename: Dockerfile
    allowed_patterns:
      - "@sha256:[a-fA-F0-9]{64}"
  - filename: sonar-project.properties
    allowed_patterns:
      - projectKey
  - filename: nginx/default.conf
    checksum: 98aac2a77fa6b7248c2a68e776dee802b1ff33199bf1f83aef633bcf1dc03e58
  - filename: public/env.json
    ignore_detectors: [filename]
  - filename: src/lib/env.ts
    ignore_detectors: [filename]
  - filename: doc/adr/0004-environment-specific-configuration.md
    ignore_detectors: [filename]
scopeconfig:
  - scope: node
allowed_patterns:
  - uses:\ ([A-z0-9\-]+\/)*[A-z0-9\-]+@[a-fA-F0-9]{40}
  - "secrets: inherit"
  - Keycloak
  - keycloak
